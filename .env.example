# ─── Database (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/prototype_builder

# ─── Azure OpenAI (for AI chat commands) ───────────────
# Option A: Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Option B: OpenAI direct (fallback)
OPENAI_API_KEY=sk-your-key

# Option C: Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Azure Redis Cache (optional, falls back to in-memory)
AZURE_REDIS_URL=rediss://your-cache.redis.cache.windows.net:6380
AZURE_REDIS_KEY=your-redis-key

# ─── Azure Blob Storage (for asset exports/screenshots)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=prototypes

# ─── App Config ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
